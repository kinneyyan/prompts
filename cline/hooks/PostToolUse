#!/usr/bin/env bash

input=$(cat)

workspace_root=$(echo "$input" | jq -r '.workspaceRoots[0]')
tool_name=$(echo "$input" | jq -r '.postToolUse.toolName')

is_falsy() {
  [[ -z "$1" || "$1" == "null" || "$1" == "undefined" ]]
}

if [ "$tool_name" = "write_to_file" ] || [ "$tool_name" = "replace_in_file" ]; then
    absolute_path=$(echo "$input" | jq -r '.postToolUse.parameters.absolutePath')
    relative_path=$(echo "$input" | jq -r '.postToolUse.parameters.path')
    if is_falsy "$relative_path"; then
      file_path="$absolute_path"
    else
      file_path="$relative_path"
    fi
    # 检查 file_path 是否有值，并且是 .js, .jsx, .ts, .tsx, .css, .scss, .less, .md 文件
    if [ -n "$file_path" ] && [ "$file_path" != "null" ]; then
        if [[ "$file_path" =~ \.(js|jsx|ts|tsx|css|scss|less|md)$ ]]; then
            cd $workspace_root
            if command -v prettier &> /dev/null || [ -f "node_modules/.bin/prettier" ]; then
                result=$(npx prettier --write $file_path)
                if [ $? -eq 0 ]; then
                  echo "✅ format success"
                else
                  echo "❌ format failed" >&2
                  exit 1
                fi
            else
                echo "⚠️ prettier not found, skipped" >&2
                exit 1
            fi
        else
            echo "🦉 unsupported file type, skipped" >&2
        fi
    fi
fi

exit 0